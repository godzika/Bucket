# --- API ---
APP_NAME="File Share Service"
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- Auth (JWT) ---
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=60

# --- PostgreSQL ---
POSTGRES_USER=fileshare
POSTGRES_PASSWORD=fileshare
POSTGRES_DB=fileshare
# Used by the API container (host = postgres service name)
DATABASE_URL=postgresql+asyncpg://fileshare:fileshare@postgres:5432/fileshare

# --- MinIO / S3 ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_ENDPOINT_URL=http://minio:9000
# Endpoint used to build presigned URLs that browsers/clients can reach.
# Point this at the SAME origin the SPA is served from — the bundled nginx
# reverse-proxies /files/* to the minio container. Using the SPA origin avoids
# cross-origin downloads which iOS browsers silently misroute.
# Fallback when the browser Origin header is unavailable. The API prefers the
# request Origin automatically, so localhost vs LAN IP mismatches are avoided.
# Local dev:   http://localhost:5173
# LAN access:  http://<your-host-LAN-IP>:5173
S3_PUBLIC_ENDPOINT_URL=http://localhost:5173
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=files

# --- Limits ---
# Single presigned PUT max (S3-compatible limit); larger files use multipart upload.
SINGLE_PUT_MAX_BYTES=5368709120
# Maximum stored object size (S3 max is 5 TiB).
MAX_FILE_BYTES=5497558138880
MULTIPART_PART_SIZE_BYTES=67108864
MULTIPART_PART_PRESIGN_BATCH=32
PRESIGN_PUT_TTL_SECONDS=3600
PRESIGN_GET_TTL_SECONDS=900
